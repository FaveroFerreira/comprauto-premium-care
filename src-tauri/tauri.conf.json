  "productName": "comprauto-premium-care",
  "version": "0.1.0",
  "identifier": "br.com.comprautopremiumcare",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
